# RAG-MCP-DEMO 环境变量配置
# 配置说明：按模型类型分类，每个类型独立配置
# 复制此文件为 .env 并填写实际的 API 密钥

# ============================================================
# 1. LLM (大语言模型) 配置
# ============================================================
# 支持提供商: qianfan (百度千帆), openai, siliconflow

LLM_PROVIDER=qianfan
LLM_MODEL=ERNIE-Bot-4
LLM_API_KEY=your-llm-api-key
# LLM_SECRET_KEY=your-qianfan-secret-key  # 可选，标准千帆需要，Coding Plan 不需要
LLM_BASE_URL=https://aips.iquanzhong.com/aidoc-rag/qianfan  # 可选，自定义API地址

# 备选配置示例（OpenAI兼容格式）:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4
# LLM_API_KEY=sk-your-openai-key
# LLM_BASE_URL=https://api.openai.com/v1

# ============================================================
# 2. Embedding (向量嵌入) 配置
# ============================================================
# 支持提供商: siliconflow, openai

EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1  # 可选，自定义API地址

# 备选配置示例:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=sk-your-openai-key

# ============================================================
# 3. Reranker (重排序) 配置
# ============================================================
# 支持提供商: siliconflow

RERANKER_PROVIDER=siliconflow
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_API_KEY=your-reranker-api-key
RERANKER_BASE_URL=https://api.siliconflow.cn/v1  # 可选，自定义API地址

# ============================================================
# 4. 向量数据库配置
# ============================================================

VECTOR_DB_PROVIDER=chroma
VECTOR_DB_PERSIST_DIR=./chroma_db

# ============================================================
# 5. 应用配置（可选）
# ============================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 知识库文档目录
KNOWLEDGE_BASE_DIR=./knowledge_base

# MCP 服务器配置
MCP_TRANSPORT=stdio  # 可选: stdio, sse
MCP_PORT=8080        # SSE 模式时使用
